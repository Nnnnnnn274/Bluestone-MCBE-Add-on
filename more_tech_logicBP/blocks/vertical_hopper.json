{
  "format_version": "1.21.0",
  "minecraft:block": {
    "description": {
      "identifier": "bluestone:vertical_hopper",
      "menu_category": { "category": "items", "group": "itemGroup.name.redstone" },
      "register_to_creative": true,
      "states": { "bluestone:powered": [false, true] }
    },
    "components": {
      "minecraft:display_name": { "value": "Bluestone Vertical Hopper" },
      "minecraft:container": { "size": 27 },
      "minecraft:destructible_by_mining": { "seconds_to_destroy": 1.0 },
      "minecraft:destructible_by_explosion": { "explosion_resistance": 1 },
      "minecraft:map_color": "#1d65ff",
      "minecraft:light_dampening": 0,
      "minecraft:material_instances": { "*": { "render_method": "opaque", "texture": "bluestone_vertical_hopper" } }
    },
    "permutations": [
      {
        "condition": "q.block_state('bluestone:powered') == true",
        "components": {
          "minecraft:material_instances": { "*": { "render_method": "opaque", "texture": "bluestone_vertical_hopper" } },
          "minecraft:map_color": "#6ec8ff"
        }
      }
    ]
  }
}

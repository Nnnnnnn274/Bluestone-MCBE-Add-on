{
  "format_version": "1.21.0",
  "minecraft:block": {
    "description": {
      "identifier": "bluestone:greenstone_connector",
      "menu_category": {
        "category": "items",
        "group": "itemGroup.name.redstone"
      },
      "register_to_creative": true,
      "states": {
        "bluestone:powered": [false, true],
        "greenstone:powered": [false, true]
      }
    },
    "components": {
      "minecraft:display_name": { "value": "Greenstone-Bluestone Connector" },
      "minecraft:destructible_by_mining": { "seconds_to_destroy": 0.35 },
      "minecraft:destructible_by_explosion": { "explosion_resistance": 1 },
      "minecraft:map_color": "#2a8c2a",
      "minecraft:light_dampening": 0,
      "minecraft:material_instances": { "*": { "render_method": "opaque", "texture": "greenstone_connector_off" } }
    },
    "permutations": [
      {
        "condition": "q.block_state('bluestone:powered') == true || q.block_state('greenstone:powered') == true",
        "components": {
          "minecraft:material_instances": { "*": { "render_method": "opaque", "texture": "greenstone_connector_on" } },
          "minecraft:map_color": "#7dff7d",
          "minecraft:light_emission": 6
        }
      }
    ]
  }
}

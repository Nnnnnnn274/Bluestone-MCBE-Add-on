{
  "format_version": "1.21.0",
  "minecraft:block": {
    "description": {
      "identifier": "bluestone:assembler",
      "menu_category": {
        "category": "items",
        "group": "itemGroup.name.redstone"
      },
      "states": { "bluestone:powered": [false, true] }
    },
    "components": {
      "minecraft:display_name": { "value": "Bluestone Assembler" },
      "minecraft:container": { "size": 9 },
      "minecraft:destructible_by_mining": { "seconds_to_destroy": 1.5 },
      "minecraft:destructible_by_explosion": { "explosion_resistance": 1 },
      "minecraft:map_color": "#1d65ff",
      "minecraft:light_dampening": 0,
      "minecraft:material_instances": { "*": { "render_method": "opaque", "texture": "bluestone_lamp_off" } }
    },
    "permutations": [
      {
        "condition": "q.block_state('bluestone:powered') == true",
        "components": {
          "minecraft:material_instances": { "*": { "render_method": "opaque", "texture": "bluestone_lamp_on" } },
          "minecraft:map_color": "#6ec8ff"
        }
      }
    ]
  }
}
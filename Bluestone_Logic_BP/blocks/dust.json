{
    "format_version": "1.21.0",
    "minecraft:block": {
        "description": {
            "identifier": "bluestone:dust",
            "menu_category": {
                "category": "items",
                "group": "itemGroup.name.redstone"
            },
            "states": {
                "bluestone:powered": [false, true]
            }
        },
        "components": {
            "minecraft:display_name": "Bluestone Dust",
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 0.35
            },
            "minecraft:destructible_by_explosion": {
                "explosion_resistance": 1
            },
            "minecraft:map_color": "#1d65ff",
            "minecraft:light_dampening": 0,
            "minecraft:geometry": "geometry.bluestone_dust",
            "minecraft:material_instances": {
                "*": {
                    "texture": "bluestone_dust_off",
                    "render_method": "alpha_test",
                    "face_dimming": false,
                    "ambient_occlusion": false
                }
            },
            "minecraft:collision_box": false,
            "minecraft:selection_box": {
                "origin": [-8, 0, -8],
                "size": [16, 1, 16]
            }
        },
        "permutations": [
            {
                "condition": "q.block_state('bluestone:powered') == true",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "bluestone_dust_on",
                            "render_method": "alpha_test",
                            "face_dimming": false,
                            "ambient_occlusion": false
                        }
                    },
                    "minecraft:map_color": "#6ec8ff",
                    "minecraft:light_emission": 6
                }
            }
        ]
    }
}
